{
  "name": "bulk-todo-example",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite build && wrangler dev",
    "deploy": "vite build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:setup:local": "npm run db:generate && npm run db:migrate:local",
    "db:migrate:local": "wrangler d1 migrations apply bulk-todo-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply bulk-todo-db --remote",
    "db:studio": "drizzle-kit studio",
    "cf-typegen": "wrangler types --env-interface Bindings"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2"
  }
}
