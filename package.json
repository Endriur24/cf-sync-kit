{
  "name": "cf-sync-kit",
  "version": "0.10.1",
  "description": "A real-time framework for Cloudflare Workers with Durable Objects, Hono, and React",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "cd example/todo-app && npm run dev",
    "dev:scoped": "cd example/scoped-todos-app && npm run dev",
    "dev:auth": "cd example/auth-todo-app && npm run dev",
    "dev:roles": "cd example/project-roles-todo-app && npm run dev",
    "dev:bulk": "cd example/bulk-todo && npm run dev",
    "build": "cd example/todo-app && npm run build",
    "preview": "cd example/todo-app && npm run preview",
    "deploy": "cd example/todo-app && npm run deploy",
    "build:lib": "tsc --project tsconfig.lib.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "workspaces": [
    "example/todo-app",
    "example/scoped-todos-app",
    "example/auth-todo-app",
    "example/project-roles-todo-app",
    "example/bulk-todo"
  ],
  "peerDependencies": {
    "@hono/zod-validator": ">=0.7.0",
    "@tanstack/react-query": ">=5.0.0",
    "drizzle-orm": ">=0.40.0",
    "drizzle-zod": ">=0.8.0",
    "hono": ">=4.0.0",
    "partyserver": ">=0.4.0",
    "partysocket": ">=1.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "typescript": ">=5.0.0",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true },
    "drizzle-zod": { "optional": true }
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.3",
    "@hono/react-renderer": "^1.0.1",
    "@hono/zod-validator": "^0.7.6",
    "@tanstack/react-query": "^5.96.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.9",
    "partyserver": "^0.4.1",
    "partysocket": "^1.1.16",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.0.0",
    "vite": "^8.0.3",
    "vite-ssr-components": "^0.5.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.79.0",
    "zod": "^4.3.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Endriur24/cf-sync-kit"
  },
  "license": "MIT",
  "homepage": "https://github.com/Endriur24/cf-sync-kit#readme",
  "keywords": [
    "cloudflare",
    "workers",
    "durable-objects",
    "real-time",
    "sync",
    "websocket",
    "hono",
    "react",
    "drizzle",
    "typescript"
  ]
}
